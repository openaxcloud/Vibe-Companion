# ✅ Replit Configuration for E-Code Platform
# Vérifié: 26 Novembre 2025
# NOTE: Actual values are stored in Replit Secrets, not this file

# ═══════════════════════════════════════════════════════════════
# REPLIT DETECTION
# ═══════════════════════════════════════════════════════════════
REPLIT=true
# REPL_ID, REPL_SLUG, REPL_OWNER are auto-populated by Replit

# ═══════════════════════════════════════════════════════════════
# CORE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=5000

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
# DATABASE_URL is configured in Replit Secrets
# Uses Neon PostgreSQL serverless

# ═══════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════
# REDIS_URL is configured in Replit Secrets
REDIS_ENABLED=true

# ═══════════════════════════════════════════════════════════════
# FRONTEND BUILD (Vite)
# ═══════════════════════════════════════════════════════════════
# Auto-detected from REPLIT_DEV_DOMAIN and REPLIT_DOMAINS

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════
# SESSION_SECRET, JWT_SECRET, ENCRYPTION_KEY are in Replit Secrets
# ALLOWED_ORIGINS is configured in Replit Secrets

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════════════════════════
# All API keys are configured in Replit Secrets:
# - OPENAI_API_KEY
# - ANTHROPIC_API_KEY
# - GEMINI_API_KEY
# - XAI_API_KEY
# - MOONSHOT_API_KEY

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════
ENABLE_COLLABORATION=true
ENABLE_AI=true
ENABLE_DEPLOYMENTS=true
ENABLE_BILLING=true

# AI UX Features (configured in Replit Secrets)
# FEATURE_AI_UX_IMPROVE_PROMPT=true
# FEATURE_AI_UX_EXTENDED_THINKING=true
# FEATURE_AI_UX_HIGH_POWER_MODE=true
# FEATURE_AI_UX_PROGRESS_TAB=true
# FEATURE_AI_UX_PAUSE_RESUME=true

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════
# IMPORTANT: All sensitive values are managed in Replit Secrets
# Access via: Replit Dashboard → Secrets
# ═══════════════════════════════════════════════════════════════
