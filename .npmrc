# ═══════════════════════════════════════════════════════════════
# E-Code Platform - NPM Configuration
# Optimized for Replit Reserved VM deployment
# Domain: https://e-code.ai
# Verified: 26 November 2025 ✅
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# REPLIT OPTIMIZATION
# ─────────────────────────────────────────────────────────────────

# Enable package-lock.json (required for npm ci in deployments)
# Note: npm ci requires a package-lock.json for reproducible builds
package-lock=true

# Optional dependencies are installed by default (do not set omit=optional)

# Cache location optimized for Replit's ephemeral storage
cache=/tmp/npm-cache

# ─────────────────────────────────────────────────────────────────
# DEPENDENCY MANAGEMENT
# ─────────────────────────────────────────────────────────────────

# Use legacy peer deps to avoid React/Node.js conflicts
# Required for many packages that haven't updated peer deps
legacy-peer-deps=true

# Install all dependencies including devDeps (vite, esbuild needed to build on VM)
# Playwright browser downloads are skipped separately via playwright_skip_browser_download
production=false

# Skip Playwright browser downloads during npm install (~500MB savings)
# Playwright checks npm_config_playwright_skip_browser_download at postinstall time
playwright_skip_browser_download=1

# ─────────────────────────────────────────────────────────────────
# PERFORMANCE & NETWORK (Optimized for fast deployment)
# ─────────────────────────────────────────────────────────────────

# Reduce network retries for faster failure detection
fetch-retries=1
fetch-retry-mintimeout=5000
fetch-retry-maxtimeout=30000

# Allow downloading packages when needed
prefer-offline=false

# Reduce progress output for faster CI
progress=false

# Maximize concurrent connections
maxsockets=50

# Skip audit in CI for speed
audit=false

# Do NOT omit optional deps - esbuild linux binaries are optional deps
# omit=optional

# Ignore postinstall scripts of dependencies (faster)
ignore-scripts=false

# ─────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────

# Enforce strict SSL verification
strict-ssl=true

# Security audit level (moderate = skip low severity)
audit-level=moderate

# ─────────────────────────────────────────────────────────────────
# NOISE REDUCTION
# ─────────────────────────────────────────────────────────────────

# Disable npm fund messages
fund=false

# Disable update notifier
update-notifier=false
