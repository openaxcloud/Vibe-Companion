# E-Code Platform - Environment Configuration Template
# Copy this file to .env and fill in the values

# ===========================================
# Core Settings
# ===========================================
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=

# ===========================================
# Security Secrets
# ===========================================
# Generate secure random values: openssl rand -base64 32
SESSION_SECRET=
JWT_SECRET=

# ===========================================
# Redis (for caching and sessions)
# ===========================================
REDIS_PASSWORD=

# ===========================================
# AI API Keys
# ===========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
XAI_API_KEY=

# ===========================================
# Feature Flags
# ===========================================
ENABLE_COLLABORATION=true
ENABLE_AI=true
ENABLE_DEPLOYMENTS=true
ENABLE_BILLING=false
ENABLE_ANALYTICS=true

# ===========================================
# Development Settings
# ===========================================
LOG_LEVEL=debug
DISABLE_CSRF=false

# ===========================================
# WebSocket Security
# ===========================================
ALLOWED_ORIGINS=
REPLIT_DOMAINS=

# ===========================================
# External Services (Optional)
# ===========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENTRY_DSN=
SLACK_WEBHOOK_URL=
