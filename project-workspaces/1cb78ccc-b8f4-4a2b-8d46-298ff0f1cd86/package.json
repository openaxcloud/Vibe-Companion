{
  "name": "ecommerce-marketplace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "ts-node-dev --respawn --transpile-only server/src/index.ts",
    "client": "vite --config client/vite.config.ts --host 0.0.0.0",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server",
    "build:client": "vite build --config client/vite.config.ts",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/client": "latest",
    "axios": "latest",
    "bcryptjs": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "jsonwebtoken": "latest",
    "lucide-react": "latest",
    "nodemailer": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "stripe": "latest",
    "zustand": "latest",
    "@stripe/stripe-js": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "ts-node": "latest",
    "ts-node-dev": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
