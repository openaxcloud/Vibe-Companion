{
  "name": "ai-chatbot",
  "version": "1.0.0",
  "description": "Intelligent AI Chatbot with OpenAI GPT-4.1 integration",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.ts",
    "client": "cd client && npm start",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "tsc server/index.ts --outDir dist",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.1",
    "socket.io": "^4.7.4",
    "mongoose": "^7.6.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "csv-parse": "^5.5.2",
    "vm2": "^3.9.19",
    "puppeteer": "^21.5.0",
    "i18next": "^23.6.0",
    "i18next-fs-backend": "^2.3.0",
    "dotenv": "^16.3.1",
    "@pinecone-database/pinecone": "^1.1.2",
    "langchain": "^0.0.190"
  },
  "devDependencies": {
    "@types/node": "^20.8.7",
    "@types/express": "^4.17.20",
    "@types/cors": "^2.8.15",
    "@types/multer": "^1.4.9",
    "@types/bcryptjs": "^2.4.5",
    "@types/jsonwebtoken": "^9.0.4",
    "typescript": "^5.2.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.2"
  }
}