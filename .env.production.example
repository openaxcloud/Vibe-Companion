# E-Code Platform - Production Environment Variables
# Copy this file to .env.production and fill in the values

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
# Set to 'single-vm' to disable Kubernetes modules
# Set to 'kubernetes' to enable K8s orchestration (requires cluster)
DEPLOYMENT_MODE=single-vm
KUBERNETES_ENABLED=false

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://ecode:${POSTGRES_PASSWORD}@postgres:5432/ecode

# =============================================================================
# REDIS (Cache & WebSocket PubSub)
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# AI PROVIDERS (Required)
# =============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
XAI_API_KEY=...
MOONSHOT_API_KEY=...

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
SENDGRID_API_KEY=SG....
SENTRY_DSN=https://...@sentry.io/...
VITE_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# =============================================================================
# SECURITY
# =============================================================================
SESSION_SECRET=your_32_char_random_string_here
JWT_SECRET=your_jwt_secret_here

# [REQUIRED] Comma-separated list of allowed CORS origins.
# In production, requests from unlisted origins are rejected with 403.
# Format: ALLOWED_ORIGINS=https://domain1.com,https://domain2.com
# On Replit, REPLIT_DOMAINS is used as fallback ONLY when ALLOWED_ORIGINS is unset.
ALLOWED_ORIGINS=https://e-code.ai

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=production
PORT=5000
APP_URL=https://e-code.ai
FRONTEND_URL=https://e-code.ai

# =============================================================================
# DOCKER EXECUTION (For user code sandboxing)
# =============================================================================
EXECUTION_MODE=docker
DOCKER_HOST=tcp://docker:2376
DOCKER_TLS_VERIFY=1
DOCKER_CERT_PATH=/certs/client
DOCKER_NETWORK=ecode-network
