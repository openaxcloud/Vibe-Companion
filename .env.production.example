# E-Code Platform - Production Environment Variables
# Copy this file to .env.production and fill in the values

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
DEPLOYMENT_MODE=single-vm
KUBERNETES_ENABLED=false

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_PASSWORD=
DATABASE_URL=

# =============================================================================
# REDIS (Cache & WebSocket PubSub)
# =============================================================================
REDIS_URL=

# =============================================================================
# AI PROVIDERS (Required)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SLACK_WEBHOOK_URL=

# =============================================================================
# SECURITY
# =============================================================================
SESSION_SECRET=
JWT_SECRET=

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=production
PORT=5000
APP_URL=
FRONTEND_URL=

# =============================================================================
# DOCKER EXECUTION (For user code sandboxing)
# =============================================================================
EXECUTION_MODE=docker
DOCKER_HOST=
DOCKER_TLS_VERIFY=
DOCKER_CERT_PATH=
DOCKER_NETWORK=
