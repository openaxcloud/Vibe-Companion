# ============================================================================
# Vibe-Companion / E-code — Production environment template
# ============================================================================
# Copy to `.env.production` (or set as platform secrets) and fill in values.
# Variables marked [REQUIRED] must be set or the server will refuse to boot.
# Variables marked [RECOMMENDED] enable production-grade features but degrade
# gracefully if absent. Everything else is optional / per-feature.
#
# Generated from `grep -rh "process.env\.[A-Z_]\+" server/ shared/ client/src/`
# (341 distinct vars across the codebase). Only the production-relevant ones
# are listed here; consult the source for niche flags.
# ============================================================================

# ---------------------------------------------------------------------------
# Core runtime [REQUIRED]
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/ecode
SESSION_SECRET=                    # 32+ random chars, see `openssl rand -hex 32`
ENCRYPTION_KEY=                    # 32+ random chars, used for at-rest secret encryption

# ---------------------------------------------------------------------------
# Public URLs [REQUIRED for OAuth, emails, share links]
# ---------------------------------------------------------------------------
APP_URL=https://your-domain.com
APP_DOMAIN=your-domain.com
BASE_URL=https://your-domain.com
API_BASE_URL=https://your-domain.com/api
ASSET_BASE_URL=                    # CDN base URL (optional)
ALLOWED_ORIGINS=https://your-domain.com
COOKIE_DOMAIN=                     # leave empty unless cross-subdomain cookies needed

# ---------------------------------------------------------------------------
# Replit-specific (auto-injected on Replit Deployments — leave empty elsewhere)
# ---------------------------------------------------------------------------
REPL_ID=
REPL_SLUG=
REPLIT_DOMAINS=

# ---------------------------------------------------------------------------
# Deployment mode (single-vm = Replit/standard host, kubernetes = legacy archive)
# ---------------------------------------------------------------------------
DEPLOYMENT_MODE=single-vm
KUBERNETES_ENABLED=false

# ---------------------------------------------------------------------------
# AI providers [at least one REQUIRED for code generation]
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=                 # Primary — Claude Opus 4.7 / Sonnet 4.6 / Haiku 4.5
OPENAI_API_KEY=                    # Fallback — GPT-4.1 / o3 / o4-mini
GEMINI_API_KEY=                    # Fallback — Gemini 2.5 Pro / Flash
XAI_API_KEY=                       # Optional — Grok-3
MOONSHOT_API_KEY=                  # Optional — Kimi-K2
GROQ_API_KEY=                      # Optional — Mixtral / Llama 3
# AI_INTEGRATIONS_*_API_KEY are alternates auto-detected when running on Replit
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_XAI_API_KEY=
AI_INTEGRATIONS_MOONSHOT_API_KEY=
AI_INTEGRATIONS_GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Billing & payments [REQUIRED to charge customers]
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_... # used by client

# ---------------------------------------------------------------------------
# Auth — OAuth providers [optional, per-feature]
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Email / SMTP [RECOMMENDED for verification + password reset]
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@your-domain.com
SENDGRID_API_KEY=                  # alternative to SMTP

# ---------------------------------------------------------------------------
# Object storage (S3-compatible) [RECOMMENDED for assets/uploads]
# ---------------------------------------------------------------------------
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
# AWS_* aliases are accepted as fallback
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Redis [RECOMMENDED for rate-limit + cache; falls back to in-memory if absent]
# ---------------------------------------------------------------------------
REDIS_ENABLED=true
REDIS_URL=redis://default:password@host:6379
REDIS_USE_TLS=true
REDIS_DEFAULT_TTL=3600

# ---------------------------------------------------------------------------
# Monitoring [RECOMMENDED — Sentry + Slack alerting]
# ---------------------------------------------------------------------------
SENTRY_DSN=                        # if unset, Sentry is disabled (graceful)
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SLACK_WEBHOOK_URL=                 # incident pings
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_WEBHOOK_URL=               # alternative to Slack

# ---------------------------------------------------------------------------
# Search / external APIs [optional, per-feature]
# ---------------------------------------------------------------------------
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
BING_SEARCH_API_KEY=
PERPLEXITY_API_KEY=

# ---------------------------------------------------------------------------
# CDN / edge [optional, per-strategy]
# ---------------------------------------------------------------------------
CDN_ENABLED=false
CDN_BASE_URL=
CLOUDFLARE_ENABLED=false
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFRONT_ENABLED=false

# ---------------------------------------------------------------------------
# TLS / ACME [optional — only if managing certs in-app]
# ---------------------------------------------------------------------------
ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory
ACME_EMAIL=
ACME_STAGING=false

# ---------------------------------------------------------------------------
# Admin & operations
# ---------------------------------------------------------------------------
ADMIN_EMAIL=                       # super-admin account email
ADMIN_USER_PASSWORD=               # if unset, a random password is generated and printed at first seed
TEST_USER_PASSWORD=                # dev-only test account; ignored in production
ADMIN_API_KEY=                     # required to call /api/admin/* server-to-server
ADMIN_ALERT_EMAILS=                # comma-separated list for security alerts
ADMIN_IP_WHITELIST=                # comma-separated CIDRs allowed to access admin UI
ALLOW_ALL_ADMIN_IPS=false          # NEVER set to true in production

# ---------------------------------------------------------------------------
# Misc / advanced
# ---------------------------------------------------------------------------
BEHIND_PROXY=true                  # required when running behind a reverse proxy
APP_VERSION=                       # set by CI; falls back to package.json version
ANALYTICS_ENABLED=false
