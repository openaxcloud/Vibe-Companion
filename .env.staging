# Staging Environment Configuration
# S-C2 FIXED: All secrets must come from Replit Secrets panel, NEVER commit credentials
NODE_ENV=staging
PORT=5000

# Database Configuration - Staging
# Set DATABASE_URL via Replit Secrets panel
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2

# API URLs
API_URL=https://staging-api.e-code.ai
APP_URL=https://staging.e-code.ai

# SendGrid Configuration
# Set SENDGRID_API_KEY via Replit Secrets panel
FROM_EMAIL=noreply@staging.e-code.ai
FROM_NAME="E-Code Platform (Staging)"

# Monitoring
LOG_LEVEL=debug
ENABLE_MONITORING=true
ENABLE_PERFORMANCE_TRACKING=true

# Security
# Set JWT_SECRET and SESSION_SECRET via Replit Secrets panel
# Generate with: openssl rand -hex 64

# AI Services
# Set all API keys via Replit Secrets panel:
# OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY, XAI_API_KEY, MOONSHOT_API_KEY

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_DEBUG_MODE=true
ENABLE_STAGING_FEATURES=true
ENABLE_EMAIL_NOTIFICATIONS=true

# Health Check
HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_CHECK_TIMEOUT_MS=5000