// This is the Prisma schema file for the backend service

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum ChannelType {
  PUBLIC
  PRIVATE
  DIRECT
}

enum MessageType {
  NORMAL
  SYSTEM
  FILE
}

enum ReactionType {
  LIKE
  LOVE
  LAUGH
  WOW
  SAD
  ANGRY
  THUMBS_UP
  THUMBS_DOWN
  CUSTOM
}

enum PresenceStatus {
  ONLINE
  OFFLINE
  AWAY
  DO_NOT_DISTURB
}

enum FileType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

model User {
  id             String              @id @default(uuid())
  email          String              @unique
  username       String              @unique
  displayName    String?
  passwordHash   String
  avatarUrl      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  workspaces     WorkspaceMember[]
  messages       Message[]
  reactions      Reaction[]
  fileUploads    FileUpload[]
  presences      UserPresence[]
  directMessagesSent     DirectMessage[] @relation("DirectMessagesSent")
  directMessagesReceived DirectMessage[] @relation("DirectMessagesReceived")
}

model Workspace {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  ownerId     String
  owner       User               @relation(fields: [ownerId], references: [id])

  members     WorkspaceMember[]
  channels    Channel[]
}

model WorkspaceMember {
  id           String        @id @default(uuid())
  userId       String
  workspaceId  String
  role         WorkspaceRole @default(MEMBER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model Channel {
  id           String        @id @default(uuid())
  name         String
  topic        String?
  type         ChannelType   @default(PUBLIC)
  isArchived   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])

  messages     Message[]
}

model Message {
  id           String        @id @default(uuid())
  content      String?
  type         MessageType   @default(NORMAL)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  isEdited     Boolean       @default(false)
  isDeleted    Boolean       @default(false)

  authorId     String
  channelId    String

  author       User          @relation(fields: [authorId], references: [id])
  channel      Channel       @relation(fields: [channelId], references: [id])

  reactions    Reaction[]
  fileUploads  FileUpload[]

  @@index([channelId, createdAt])
  @@index([authorId, createdAt])
}

model Reaction {
  id          String       @id @default(uuid())
  type        ReactionType
  emoji       String?      // For custom emoji identifiers or unicode
  createdAt   DateTime     @default(now())

  messageId   String
  userId      String

  message     Message      @relation(fields: [messageId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, type, emoji])
  @@index([messageId])
  @@index([userId])
}

model FileUpload {
  id           String     @id @default(uuid())
  url          String
  fileName     String
  mimeType     String
  fileType     FileType   @default(OTHER)
  sizeBytes    Int
  createdAt    DateTime   @default(now())

  messageId    String?
  uploaderId   String

  message      Message?   @relation(fields: [messageId], references: [id])
  uploader     User       @relation(fields: [uploaderId], references: [id])

  @@index([messageId])
  @@index([uploaderId, createdAt])
}

model DirectMessage {
  id           String     @id @default(uuid())
  content      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isEdited     Boolean    @default(false)
  isDeleted    Boolean    @default(false)

  senderId     String
  receiverId   String

  sender       User       @relation("DirectMessagesSent", fields: [senderId], references: [id])
  receiver     User       @relation("DirectMessagesReceived", fields: [receiverId], references: [id])

  reactions    DirectMessageReaction[]
  fileUploads  DirectMessageFile[]

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

model DirectMessageReaction {
  id              String       @id @default(uuid())
  type            ReactionType
  emoji           String?
  createdAt       DateTime     @default(now())

  directMessageId String
  userId          String

  directMessage   DirectMessage @relation(fields: [directMessageId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@unique([directMessageId, userId, type, emoji])
  @@index([directMessageId])
  @@index([userId])
}

model DirectMessageFile {
  id              String     @id @default(uuid())
  url             String
  fileName        String
  mimeType        String
  fileType        FileType   @default(OTHER)
  sizeBytes       Int
  createdAt       DateTime   @default(now())

  directMessageId String
  uploaderId      String

  directMessage   DirectMessage @relation(fields: [directMessageId], references: [id])
  uploader        User          @relation(fields: [uploaderId], references: [id])

  @@index([directMessageId])
  @@index([uploaderId, createdAt])
}

model UserPresence {
  id            String         @id @default(uuid())
  userId        String
  workspaceId   String
  status        PresenceStatus @default(OFFLINE)
  lastActiveAt  DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  device        String?        // e.g., "web", "mobile", "desktop"
  ipAddress     String?

  user          User           @relation(fields: [userId], references: [id])
  workspace     Workspace      @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
  @@index([workspaceId, status])
}