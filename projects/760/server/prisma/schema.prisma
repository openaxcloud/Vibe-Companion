generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  username         String             @unique
  displayName      String?
  avatarUrl        String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  channelsOwned    Channel[]          @relation("ChannelOwner")
  channelMembers   ChannelMember[]
  directThreadsA   DirectThread[]     @relation("DirectThreadUserA")
  directThreadsB   DirectThread[]     @relation("DirectThreadUserB")
  directParticipants DirectThreadParticipant[]
  messages         Message[]
  reactions        Reaction[]
  readReceipts     ReadReceipt[]
  fileAssets       FileAsset[]        @relation("FileAssetUploader")
  pushSubscriptions PushSubscription[]
  presences        Presence[]

  @@index([email])
  @@index([username])
}

model Channel {
  id           String           @id @default(cuid())
  name         String
  isPrivate    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  ownerId      String
  owner        User             @relation("ChannelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      ChannelMember[]
  messages     Message[]

  @@index([isPrivate])
  @@index([ownerId])
  @@unique([name])
}

model ChannelMember {
  id         String    @id @default(cuid())
  userId     String
  channelId  String
  role       ChannelRole @default(MEMBER)
  joinedAt   DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
  @@index([userId])
}

enum ChannelRole {
  OWNER
  ADMIN
  MEMBER
}

model DirectThread {
  id           String                       @id @default(cuid())
  isGroup      Boolean                      @default(false)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  // Optional optimized fields for 1:1 threads
  userAId      String?
  userBId      String?
  userA        User?                        @relation("DirectThreadUserA", fields: [userAId], references: [id], onDelete: SetNull)
  userB        User?                        @relation("DirectThreadUserB", fields: [userBId], references: [id], onDelete: SetNull)

  participants DirectThreadParticipant[]
  messages     Message[]

  @@index([isGroup])
  @@index([userAId, userBId])
}

model DirectThreadParticipant {
  id             String        @id @default(cuid())
  directThreadId String
  userId         String
  joinedAt       DateTime      @default(now())

  directThread   DirectThread  @relation(fields: [directThreadId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([directThreadId, userId])
  @@index([userId])
  @@index([directThreadId])
}

model Message {
  id               String        @id @default(cuid())
  content          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  channelId        String?
  directThreadId   String?
  authorId         String
  parentMessageId  String?

  channel          Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  directThread     DirectThread? @relation(fields: [directThreadId], references: [id], onDelete: Cascade)
  author           User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentMessage    Message?      @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: Cascade)
  replies          Message[]     @relation("MessageThread")
  reactions        Reaction[]
  readReceipts     ReadReceipt[]
  fileAssets       FileAsset[]

  @@index([channelId, createdAt])
  @@index([directThreadId, createdAt])
  @@index([authorId])
  @@index([parentMessageId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  messageId String
  userId    String

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model ReadReceipt {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  messageId  String
  userId     String

  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([userId, createdAt])
}

model FileAsset {
  id          String   @id @default(cuid())
  path        String
  mimeType    String
  size        Int
  createdAt   DateTime @default(now())

  uploaderId  String
  messageId   String?

  uploader    User     @relation("FileAssetUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  message     Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([messageId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([endpoint])
  @@index([userId])
}

model Presence {
  id        String       @id @default(cuid())
  status    PresenceStatus @default(OFFLINE)
  lastSeen  DateTime?
  updatedAt DateTime     @updatedAt

  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lastSeen])
}

enum PresenceStatus {
  ONLINE
  AWAY
  DND
  OFFLINE
}