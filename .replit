modules = ["nodejs-20", "postgresql-16"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 NODE_ENV=development node --import tsx/esm server/index.ts"
waitForPort = 5000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
RUNNER_MODE = "local"
OPENHANDS_SERVER_URL = "https://app.all-hands.dev"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3000

[[ports]]
localPort = 5175
externalPort = 3003

[[ports]]
localPort = 26602
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "NODE_ENV=production node dist/index.cjs"]
build = ["sh", "-c", "npx tsx script/build.ts"]
