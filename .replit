modules = ["nodejs-20"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 NODE_ENV=development node --import tsx/esm server/index.ts"
waitForPort = 5000

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "NODE_ENV=production PORT=5000 node --import tsx/esm server/index.ts"]
build = ["sh", "-c", "NODE_OPTIONS='--max-old-space-size=4096' npx vite build"]

[[ports]]
localPort = 5000
externalPort = 80

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
